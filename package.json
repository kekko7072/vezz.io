{
  "name": "vezz.io",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "edit": "VITE_ENABLE_EDITOR=true vite dev",
    "editor": "VITE_ENABLE_EDITOR=true vite dev --open /editor",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "functions:build": "npm --prefix functions run build",
    "mcp:build": "npm --prefix mcp run build",
    "articles:import": "npm --prefix mcp run import:local",
    "deploy:saved": "set -a; [ ! -f .env.local ] || . ./.env.local; set +a; npm run deploy",
    "deploy": "npm run build && npm run functions:build && firebase deploy --only hosting,functions,firestore:rules,firestore:indexes"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^3.0.0",
    "@sveltejs/adapter-node": "^5.4.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^3.0.0",
    "@tailwindcss/postcss": "^4.1.17",
    "svelte": "^4.0.0",
    "svelte-check": "^3.6.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "type": "module",
  "dependencies": {
    "autoprefixer": "^10.4.21",
    "marked": "^17.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17"
  }
}
